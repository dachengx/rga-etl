# RGA
RGA_MODEL=RGA200
RGA_BAUD_RATE=28800
RGA_USB_SERIAL_DEVICE_IDENTIFIER=/dev/tty.usbserial-FTEIZFXM

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=rga_user
MYSQL_PASSWORD=rgapw
MYSQL_DB=rga

# Execution
RGA_INITIAL_MASS=1
RGA_FINAL_MASS=200
RGA_RESOLUTION=10
RGA_SCAN_SPEED=3
RGA_MASSES=2,18,28,32,44
RGA_SCAN_TOTAL_TIME=10
RGA_SCAN_TIME_INTERVAL=1
FAKE_EXECUTION=1
