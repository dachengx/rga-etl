          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\r\n  -- Convert relative time to absolute timestamp\r\n  s.started_at + INTERVAL p.time SECOND AS time,\r\n  -- One series per mass\r\n  CONCAT('m=', p.mass) AS metric,\r\n  -- Use intensity exactly as stored\r\n  p.intensity AS value\r\nFROM p_vs_t_scan_points p\r\nJOIN p_vs_t_scans s\r\n  ON p.scan_id = s.id\r\nWHERE\r\n  p.scan_id = (SELECT id FROM p_vs_t_scans ORDER BY started_at DESC LIMIT 1)\r\n  AND p.mass IN (${p_vs_t_scan_mass:csv})\r\nORDER BY time;\r\n",
          "refId": "PvsTScan",
